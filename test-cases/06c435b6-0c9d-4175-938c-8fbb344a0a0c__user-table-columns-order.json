{
  "id": "user-table-columns-order",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "user-table-columns-order",
    "title": "User table renders exactly five columns in the correct order",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "User table",
        "locatorHint": "[data-testid='users-table']"
      },
      {
        "id": "s4",
        "action": "assertCount",
        "targetDescription": "Header columns count",
        "locatorHint": "[data-testid='users-table'] thead th"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Column 1: User information",
        "locatorHint": "[data-testid='users-table'] thead th:nth-child(1)",
        "assertion": "User information"
      },
      {
        "id": "s6",
        "action": "assertText",
        "targetDescription": "Column 2: Role",
        "locatorHint": "[data-testid='users-table'] thead th:nth-child(2)",
        "assertion": "Role"
      },
      {
        "id": "s7",
        "action": "assertText",
        "targetDescription": "Column 3: Status",
        "locatorHint": "[data-testid='users-table'] thead th:nth-child(3)",
        "assertion": "Status"
      },
      {
        "id": "s8",
        "action": "assertText",
        "targetDescription": "Column 4: Last active",
        "locatorHint": "[data-testid='users-table'] thead th:nth-child(4)",
        "assertion": "Last active"
      },
      {
        "id": "s9",
        "action": "assertText",
        "targetDescription": "Column 5: Account Access",
        "locatorHint": "[data-testid='users-table'] thead th:nth-child(5)",
        "assertion": "Account Access"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

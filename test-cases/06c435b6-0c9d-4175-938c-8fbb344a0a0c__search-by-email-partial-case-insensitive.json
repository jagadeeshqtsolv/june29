{
  "id": "search-by-email-partial-case-insensitive",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "search-by-email-partial-case-insensitive",
    "title": "Search by email partial string matches case-insensitively",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: user with email 'finance.lead@example.com' exists"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "clear",
        "targetDescription": "Clear search input",
        "locatorHint": "input[placeholder='Search user']"
      },
      {
        "id": "s4",
        "action": "typeText",
        "targetDescription": "Type uppercase partial 'FINANCE.'",
        "locatorHint": "input[placeholder='Search user']",
        "value": "FINANCE."
      },
      {
        "id": "s5",
        "action": "waitForVisible",
        "targetDescription": "Filtered row appears",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s6",
        "action": "assertContainsText",
        "targetDescription": "Row contains matching email",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child",
        "assertion": "finance.lead@example.com"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

{
  "id": "load-admin-tabs-default-and-header",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "load-admin-tabs-default-and-header",
    "title": "Admin page loads with tabs in correct order, User Management active by default, and header elements visible",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "Admin tabs bar",
        "locatorHint": "#admin-tabs"
      },
      {
        "id": "s4",
        "action": "assertText",
        "targetDescription": "Tab 1 label is 'User Management'",
        "locatorHint": "#admin-tabs li:nth-child(1)",
        "assertion": "User Management"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Tab 2 label is 'Roles & Access'",
        "locatorHint": "#admin-tabs li:nth-child(2)",
        "assertion": "Roles & Access"
      },
      {
        "id": "s6",
        "action": "assertText",
        "targetDescription": "Tab 3 label is 'Audit Log'",
        "locatorHint": "#admin-tabs li:nth-child(3)",
        "assertion": "Audit Log"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "User Management view (table container)",
        "locatorHint": "[data-testid='user-management-view']"
      },
      {
        "id": "s8",
        "action": "assertVisible",
        "targetDescription": "N Users count label",
        "locatorHint": "[data-testid='users-count']"
      },
      {
        "id": "s9",
        "action": "assertVisible",
        "targetDescription": "Search user input",
        "locatorHint": "input[placeholder='Search user']"
      },
      {
        "id": "s10",
        "action": "assertText",
        "targetDescription": "Invite user button text",
        "locatorHint": "[data-testid='invite-user-btn']",
        "assertion": "Invite user"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

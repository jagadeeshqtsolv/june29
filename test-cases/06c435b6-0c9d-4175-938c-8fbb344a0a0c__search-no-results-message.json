  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "search-no-results-message",
    "title": "Search with no results shows 'No users found for [query]' while header remains",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "clear",
        "targetDescription": "Clear search input",
        "locatorHint": "input[placeholder='Search user']"
      },
      {
        "id": "s4",
        "action": "typeText",
        "targetDescription": "Type no-match query",
        "locatorHint": "input[placeholder='Search user']",
        "value": "zzznomatch"
      },
      {
        "id": "s5",
        "action": "waitForVisible",
        "targetDescription": "Empty state message",
        "locatorHint": "[data-testid='users-empty-state']"
      },
      {
        "id": "s6",
        "action": "assertText",
        "targetDescription": "Message shows query",
        "locatorHint": "[data-testid='users-empty-state']",
        "assertion": "No users found for 'zzznomatch'."
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "Table header row remains visible",
        "locatorHint": "[data-testid='users-table'] thead"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }

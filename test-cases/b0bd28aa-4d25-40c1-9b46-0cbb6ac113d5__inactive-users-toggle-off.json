{
  "id": "inactive-users-toggle-off",
  "testPlanId": "b0bd28aa-4d25-40c1-9b46-0cbb6ac113d5",
  "requirementId": "599cb887-7072-4c97-bb09-2aa935924279",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "inactive-users-toggle-off",
    "title": "Inactive users always show Account Access toggle OFF",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "At least one inactive user is present in the table"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "[data-testid=\"salesforce-login-btn\"]"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=\"user-table\"]"
      },
      {
        "id": "s4",
        "action": "assertText",
        "targetDescription": "Find an Inactive status badge",
        "locatorHint": "[data-testid=\"user-row\"].is-inactive [data-testid=\"cell-status\"]",
        "assertion": "Inactive"
      },
      {
        "id": "s5",
        "action": "assertUnchecked",
        "targetDescription": "Inactive user's toggle is OFF",
        "locatorHint": "[data-testid=\"user-row\"].is-inactive [data-testid=\"access-toggle\"] input[type=\"checkbox\"]"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}

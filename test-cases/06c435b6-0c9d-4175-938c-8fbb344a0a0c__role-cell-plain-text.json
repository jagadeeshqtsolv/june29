{
  "id": "role-cell-plain-text",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "role-cell-plain-text",
    "title": "Role cell displays plain text role label (e.g., Finance)",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: user 'Finance Person' exists with role 'Finance'"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Search 'Finance Person'",
        "locatorHint": "input[placeholder='Search user']",
        "value": "Finance Person"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Matching row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Role cell shows 'Finance'",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(2)",
        "assertion": "Finance"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

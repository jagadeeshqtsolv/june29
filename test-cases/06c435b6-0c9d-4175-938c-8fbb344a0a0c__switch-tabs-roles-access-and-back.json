{
  "id": "switch-tabs-roles-access-and-back",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "switch-tabs-roles-access-and-back",
    "title": "Switching between 'User Management' and 'Roles & Access' updates views",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "User Management view visible",
        "locatorHint": "[data-testid='user-management-view']"
      },
      {
        "id": "s4",
        "action": "tap",
        "targetDescription": "Click Roles & Access tab",
        "locatorHint": "#admin-tabs li:has-text('Roles & Access')"
      },
      {
        "id": "s5",
        "action": "waitForVisible",
        "targetDescription": "Roles & Access view",
        "locatorHint": "[data-testid='roles-access-view']"
      },
      {
        "id": "s6",
        "action": "tap",
        "targetDescription": "Click User Management tab",
        "locatorHint": "#admin-tabs li:has-text('User Management')"
      },
      {
        "id": "s7",
        "action": "waitForVisible",
        "targetDescription": "User Management view returns",
        "locatorHint": "[data-testid='user-management-view']"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

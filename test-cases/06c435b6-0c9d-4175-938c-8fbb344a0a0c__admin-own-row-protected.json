{
  "id": "admin-own-row-protected",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "admin-own-row-protected",
    "title": "Admin's own row has disabled toggle and shows tooltip on hover",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: Logged-in admin email is known (e.g., admin.qa@example.com); admin row is present in table"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Search current admin email",
        "locatorHint": "input[placeholder='Search user']",
        "value": "admin.qa@example.com"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Admin's own row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s5",
        "action": "assertDisabled",
        "targetDescription": "Admin's Access toggle is disabled",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child [data-testid='access-toggle'] input[type='checkbox']"
      },
      {
        "id": "s6",
        "action": "hover",
        "targetDescription": "Hover over disabled toggle",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child [data-testid='access-toggle']"
      },
      {
        "id": "s7",
        "action": "assertVisible",
        "targetDescription": "Tooltip visible",
        "locatorHint": "[data-testid='tooltip']"
      },
      {
        "id": "s8",
        "action": "assertText",
        "targetDescription": "Tooltip text",
        "locatorHint": "[data-testid='tooltip']",
        "assertion": "You cannot revoke your own access."
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

{
  "id": "status-badge-active-inactive",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "status-badge-active-inactive",
    "title": "Status cell shows 'Active' or 'Inactive' badge as appropriate",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: 'Active Person' (active) and 'Inactive Person' (inactive) users exist"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Search 'Active Person'",
        "locatorHint": "input[placeholder='Search user']",
        "value": "Active Person"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Active user row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Status badge shows Active",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(3)",
        "assertion": "Active"
      },
      {
        "id": "s6",
        "action": "clear",
        "targetDescription": "Clear search input",
        "locatorHint": "input[placeholder='Search user']"
      },
      {
        "id": "s7",
        "action": "fill",
        "targetDescription": "Search 'Inactive Person'",
        "locatorHint": "input[placeholder='Search user']",
        "value": "Inactive Person"
      },
      {
        "id": "s8",
        "action": "waitForVisible",
        "targetDescription": "Inactive user row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s9",
        "action": "assertText",
        "targetDescription": "Status badge shows Inactive",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(3)",
        "assertion": "Inactive"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

{
  "id": "user-info-email-only",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "user-info-email-only",
    "title": "User information cell for email-only account shows email on first line and initials from email prefix",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: email-only user 'lonely.user@example.com' exists; no first/last name; expected initials 'LU'"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Search email-only user",
        "locatorHint": "input[placeholder='Search user']",
        "value": "lonely.user@example.com"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Matching row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Primary line shows email only",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(1) [data-testid='user-primary']",
        "assertion": "lonely.user@example.com"
      },
      {
        "id": "s6",
        "action": "assertHidden",
        "targetDescription": "No secondary line (no name)",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(1) [data-testid='user-secondary']"
      },
      {
        "id": "s7",
        "action": "assertText",
        "targetDescription": "Avatar initials from email prefix are LU",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(1) [data-testid='avatar-initials']",
        "assertion": "LU"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

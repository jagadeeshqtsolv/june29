{
  "id": "revoke-access",
  "testPlanId": "c167edf3-bad2-4e44-b2b4-cb44aef0377d",
  "requirementId": "abff637f-7479-467c-8793-743af5876183",
  "suiteName": "Admin User Management - Smoke",
  "case": {
    "id": "revoke-access",
    "title": "Revoke access for an active user with confirmation",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Admin page",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "step2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Active user access toggle",
        "locatorHint": "css=tbody tr:first-child .access-toggle input:checked"
      },
      {
        "id": "step4",
        "action": "assertVisible",
        "targetDescription": "Revoke access dialog",
        "locatorHint": "role=dialog[name=\"Revoke access?\"]"
      },
      {
        "id": "step5",
        "action": "assertContainsText",
        "targetDescription": "Dialog message",
        "locatorHint": "role=dialog[name=\"Revoke access?\"]",
        "value": "This will prevent"
      },
      {
        "id": "step6",
        "action": "tap",
        "targetDescription": "Revoke button",
        "locatorHint": "role=button[name=\"Revoke\"]"
      },
      {
        "id": "step7",
        "action": "assertUnchecked",
        "targetDescription": "Access toggle is off",
        "locatorHint": "css=tbody tr:first-child .access-toggle input"
      },
      {
        "id": "step8",
        "action": "assertContainsText",
        "targetDescription": "Status badge updated",
        "locatorHint": "tbody tr:first-child td:nth-child(3)",
        "assertion": "Inactive"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}

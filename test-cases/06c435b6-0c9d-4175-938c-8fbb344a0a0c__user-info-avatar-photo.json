{
  "id": "user-info-avatar-photo",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "user-info-avatar-photo",
    "title": "User information cell shows SSO profile photo when available",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: user 'PhotoUser One' with SSO photo exists"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Search 'PhotoUser One'",
        "locatorHint": "input[placeholder='Search user']",
        "value": "PhotoUser One"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "First matching row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s5",
        "action": "assertVisible",
        "targetDescription": "Avatar image in User information cell",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(1) [data-testid='avatar-img']"
      },
      {
        "id": "s6",
        "action": "assertContainsText",
        "targetDescription": "Name visible in cell",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(1)",
        "assertion": "PhotoUser One"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}

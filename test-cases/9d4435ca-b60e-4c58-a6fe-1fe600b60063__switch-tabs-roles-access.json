{
  "id": "switch-tabs-roles-access",
  "testPlanId": "9d4435ca-b60e-4c58-a6fe-1fe600b60063",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management: SMOKE",
  "case": {
    "id": "switch-tabs-roles-access",
    "title": "Switch between User Management and Roles & Access tabs",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin page",
        "locatorHint": "https://qa-atlas.qtsolvdev.com/admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "step2",
        "action": "tap",
        "targetDescription": "Click Roles & Access tab",
        "locatorHint": "tab[role='tab']:has-text('Roles & Access')"
      },
      {
        "id": "step3",
        "action": "assertVisible",
        "targetDescription": "Roles & Access view is rendered",
        "locatorHint": "[data-testid='roles-access-view']"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click User Management tab",
        "locatorHint": "tab[role='tab']:has-text('User Management')"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "User Management table is visible again",
        "locatorHint": "table[data-testid='user-table']"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}

{
  "id": "pagination-controls-appear",
  "testPlanId": "9d4435ca-b60e-4c58-a6fe-1fe600b60063",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management: SMOKE",
  "case": {
    "id": "pagination-controls-appear",
    "title": "Pagination controls appear when more than 20 users",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin page with >20 users",
        "locatorHint": "https://qa-atlas.qtsolvdev.com/admin",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "step2",
        "action": "assertCount",
        "targetDescription": "Table shows 20 user rows on page 1",
        "locatorHint": "table tbody tr"
      },
      {
        "id": "step3",
        "action": "assertVisible",
        "targetDescription": "Pagination controls are visible below the table",
        "locatorHint": "[data-testid='pagination-controls']"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click Next page button",
        "locatorHint": "button:has-text('Next')"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "Previous button is now active",
        "locatorHint": "button:has-text('Previous'):not([disabled])"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}

{
  "id": "last-active-relative-time",
  "testPlanId": "b0bd28aa-4d25-40c1-9b46-0cbb6ac113d5",
  "requirementId": "599cb887-7072-4c97-bb09-2aa935924279",
  "suiteName": "Admin — User Management — Smoke",
  "case": {
    "id": "last-active-relative-time",
    "title": "Last active shows relative time string for users who have logged in",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "At least one user has logged in previously (not 'Never')"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Click Salesforce login",
        "locatorHint": "[data-testid=\"salesforce-login-btn\"]"
      },
      {
        "id": "s3",
        "action": "waitForVisible",
        "targetDescription": "User table visible",
        "locatorHint": "[data-testid=\"user-table\"]"
      },
      {
        "id": "s4",
        "action": "assertContainsText",
        "targetDescription": "A Last active cell shows relative time like 'X ago'",
        "locatorHint": "[data-testid=\"user-row\"].has-activity [data-testid=\"cell-last-active\"]",
        "assertion": "ago"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}

{
  "id": "last-active-never",
  "testPlanId": "06c435b6-0c9d-4175-938c-8fbb344a0a0c",
  "requirementId": "0bde0038-d6bb-4e5a-b08a-0925b55e4c88",
  "suiteName": "Admin — User Management — Functional Happy Paths",
  "case": {
    "id": "last-active-never",
    "title": "Last active shows 'Never' for users who have never logged in",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [
      "Test data: user 'Never User' has never logged in"
    ],
    "steps": [
      {
        "id": "s1",
        "action": "openUrl",
        "targetDescription": "Navigate to Admin URL",
        "value": "https://qa-atlas.qtsolvdev.com/admin"
      },
      {
        "id": "s2",
        "action": "tap",
        "targetDescription": "Salesforce login button",
        "locatorHint": "text=Salesforce login"
      },
      {
        "id": "s3",
        "action": "fill",
        "targetDescription": "Search 'Never User'",
        "locatorHint": "input[placeholder='Search user']",
        "value": "Never User"
      },
      {
        "id": "s4",
        "action": "waitForVisible",
        "targetDescription": "Never User row",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child"
      },
      {
        "id": "s5",
        "action": "assertText",
        "targetDescription": "Last active cell shows 'Never'",
        "locatorHint": "[data-testid='users-table'] tbody tr:first-child td:nth-child(4)",
        "assertion": "Never"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}
